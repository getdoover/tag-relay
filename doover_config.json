{
    "tag_relay": {
        "name": "tag_relay",
        "display_name": "Tag Relay",
        "type": "PRO",
        "visibility": "PUB",
        "allow_many": true,
        "description": "Relays tag values between apps, with optional CEL transforms and per-mapping UI.",
        "long_description": "README.md",
        "depends_on": [],
        "handler": "src.tag_relay.handler",
        "lambda_config": {
            "Runtime": "python3.13",
            "Timeout": 300,
            "MemorySize": 128,
            "Handler": "src.tag_relay.handler",
            "Architectures": [
                "arm64"
            ]
        },
        "export_ui_command": "NO_EXPORT",
        "config_schema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "",
            "title": "$default",
            "type": "object",
            "properties": {
                "dv_proc_subscriptions": {
                    "title": "Subscription",
                    "x-name": "dv_proc_subscriptions",
                    "x-hidden": false,
                    "type": [
                        "array",
                        "null"
                    ],
                    "x-required": false,
                    "description": "A list of channels to subscribe to.",
                    "default": [
                        "tag_values"
                    ],
                    "x-position": 0,
                    "items": {
                        "title": "Channel Subscription",
                        "x-name": "dv_proc_subscription",
                        "x-hidden": false,
                        "type": "string",
                        "x-required": true,
                        "description": "The name of the channel to subscribe to"
                    }
                },
                "dv_proc_schedules": {
                    "title": "Schedule",
                    "x-name": "dv_proc_schedules",
                    "x-hidden": false,
                    "format": "doover-schedule",
                    "type": [
                        "string",
                        "null"
                    ],
                    "x-required": false,
                    "description": "Optional cron/rate schedule. Only needed if at least one mapping uses trigger=schedule. Leave disabled otherwise.",
                    "default": null,
                    "x-position": 1
                },
                "mappings": {
                    "title": "Mappings",
                    "x-name": "mappings",
                    "x-hidden": false,
                    "type": [
                        "array",
                        "null"
                    ],
                    "x-required": false,
                    "description": "One entry per source-to-destination tag relay.",
                    "default": [],
                    "x-position": 2,
                    "items": {
                        "title": "Mapping",
                        "x-name": "mapping",
                        "x-hidden": false,
                        "type": "object",
                        "x-required": true,
                        "properties": {
                            "source_app": {
                                "title": "Source App",
                                "x-name": "source_app",
                                "x-hidden": false,
                                "format": "doover-application",
                                "type": "string",
                                "x-required": true,
                                "description": "App on this agent whose tag is being relayed.",
                                "x-position": 1
                            },
                            "source_tag": {
                                "title": "Source Tag",
                                "x-name": "source_tag",
                                "x-hidden": false,
                                "type": "string",
                                "x-required": true,
                                "description": "Name of the tag on the source app.",
                                "x-position": 2
                            },
                            "destination_app": {
                                "title": "Destination App",
                                "x-name": "destination_app",
                                "x-hidden": false,
                                "format": "doover-application",
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "x-required": false,
                                "description": "App on this agent to write the relayed value into. Leave blank to write into this Tag Relay app itself.",
                                "default": null,
                                "x-position": 3
                            },
                            "destination_tag": {
                                "title": "Destination Tag",
                                "x-name": "destination_tag",
                                "x-hidden": false,
                                "type": "string",
                                "x-required": true,
                                "description": "Name of the tag to write on the destination app.",
                                "x-position": 4
                            },
                            "transform_cel": {
                                "title": "Transform (CEL)",
                                "x-name": "transform_cel",
                                "x-hidden": false,
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "x-required": false,
                                "description": "Optional Common Expression Language expression applied to the source value before writing. The input is bound as `x`; the expression result becomes the destination value.\n\nCommon linear transform (y = m*x + b): `x * 0.5 + 10` scales by 0.5 and adds a 10 offset.\n\nMore examples: `x * 1000` (unit scale, int), `x * 1.8 + 32` (Celsius -> Fahrenheit), `x > 10` (threshold to boolean), `int(x / 100)` (truncate). Whenever you include a decimal point anywhere in the expression (e.g. `0.5`, `1.8`), integer inputs and integer literals are auto-promoted to double \u2014 no need for explicit casts in typical linear transforms.",
                                "default": null,
                                "x-position": 5
                            },
                            "trigger": {
                                "enum": [
                                    "event",
                                    "schedule"
                                ],
                                "title": "Trigger",
                                "x-name": "trigger",
                                "x-hidden": false,
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "x-required": false,
                                "description": "`event` (default): relay whenever the source tag changes. `schedule`: relay only on the processor's scheduled runs \u2014 requires the top-level schedule to be configured.",
                                "default": "event",
                                "x-position": 6
                            },
                            "ui": {
                                "title": "UI",
                                "x-name": "ui",
                                "x-hidden": false,
                                "type": "object",
                                "x-required": true,
                                "x-position": 7,
                                "properties": {
                                    "show_on_tag_relay_ui": {
                                        "title": "Show on Tag Relay UI",
                                        "x-name": "show_on_tag_relay_ui",
                                        "x-hidden": false,
