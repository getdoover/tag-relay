                                            "boolean",
                                            "null"
                                        ],
                                        "x-required": false,
                                        "description": "If on, surface the relayed value as a variable on the Tag Relay app's UI.",
                                        "default": false,
                                        "x-position": 1
                                    },
                                    "display_name": {
                                        "title": "Display Name",
                                        "x-name": "display_name",
                                        "x-hidden": false,
                                        "type": [
                                            "string",
                                            "null"
                                        ],
                                        "x-required": false,
                                        "description": "Label shown on the UI.",
                                        "default": null,
                                        "x-position": 2
                                    },
                                    "variable_type": {
                                        "enum": [
                                            "numeric",
                                            "boolean",
                                            "text"
                                        ],
                                        "title": "Variable Type",
                                        "x-name": "variable_type",
                                        "x-hidden": false,
                                        "type": [
                                            "string",
                                            "null"
                                        ],
                                        "x-required": false,
                                        "default": "numeric",
                                        "x-position": 3
                                    },
                                    "units": {
